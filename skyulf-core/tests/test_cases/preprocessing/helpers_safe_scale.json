{
  "params": "input_values, expected",
  "test_cases": {
    "replaces_zeros_with_one": {
      "input_values": [0.0, 2.0, 0.0, 5.0],
      "expected": [1.0, 2.0, 1.0, 5.0]
    },
    "mutates_input_array": {
      "input_values": [0.0, 3.0],
      "expected": [1.0, 3.0]
    },
    "no_zeros_is_noop": {
      "input_values": [2.0, 4.0, 8.0],
      "expected": [2.0, 4.0, 8.0]
    }
  }
}
