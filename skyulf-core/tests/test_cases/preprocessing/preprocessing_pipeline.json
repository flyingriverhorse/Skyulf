{
  "groups": {
    "diff_generated_columns": {
      "params": "df_before, df_after, expected",
      "test_cases": {
        "adds_new_column": {
          "df_before": {"a": [1.0], "b": [2.0]},
          "df_after": {"a": [1.0], "b": [2.0], "c": [3.0]},
          "expected": ["c"]
        },
        "no_new_columns": {
          "df_before": {"a": [1.0]},
          "df_after": {"a": [1.0]},
          "expected": []
        },
        "incompatible_types": {
          "df_before": "not_a_frame",
          "df_after": {},
          "expected": null
        }
      }
    },
    "count_winsorize_diffs_simple": {
      "params": "before, after, expected",
      "test_cases": {
        "identical_frames": {
          "before": {"x": [1.0, 2.0, 3.0]},
          "after": {"x": [1.0, 2.0, 3.0]},
          "expected": 0
        },
        "shape_mismatch": {
          "before": {"x": [1.0, 2.0]},
          "after": {"x": [1.0, 2.0, 3.0]},
          "expected": 0
        },
        "modified_cell": {
          "before": {"x": [1.0, 2.0, 3.0]},
          "after": {"x": [99.0, 2.0, 3.0]},
          "expected": 1
        },
        "non_tuple_non_dataframe": {
          "before": "not_a_frame",
          "after": 123,
          "expected": 0
        }
      }
    },
    "count_winsorize_diffs_tuple": {
      "params": "before_x, before_y, after_x, after_y, expected",
      "test_cases": {
        "x_and_y_changes": {
          "before_x": {"a": [1.0, 2.0]},
          "before_y": [0, 1],
          "after_x": {"a": [99.0, 2.0]},
          "after_y": [0, 5],
          "expected": 2
        },
        "no_changes": {
          "before_x": {"a": [1.0, 2.0]},
          "before_y": [0, 1],
          "after_x": {"a": [1.0, 2.0]},
          "after_y": [0, 1],
          "expected": 0
        }
      }
    },
    "metrics_from_fitted_params_copies_keys": {
      "params": "transformer_type, fitted_params, df_before, df_after, expected_metrics",
      "test_cases": {
        "feature_selection_keys": {
          "transformer_type": "UnivariateSelection",
          "fitted_params": {
            "feature_scores": {"a": 1.0},
            "p_values": {"a": 0.01},
            "feature_importances": {"a": 0.5},
            "variances": {"a": 2.0},
            "ranking": {"a": 1},
            "selected_columns": ["a"]
          },
          "df_before": {},
          "df_after": {},
          "expected_metrics": {
            "feature_scores": {"a": 1.0},
            "p_values": {"a": 0.01},
            "feature_importances": {"a": 0.5},
            "variances": {"a": 2.0},
            "ranking": {"a": 1},
            "selected_columns": ["a"]
          }
        },
        "outlier_warnings_and_bounds": {
          "transformer_type": "IQR",
          "fitted_params": {
            "warnings": ["clipped col a"],
            "bounds": {"a": [0.0, 10.0]}
          },
          "df_before": {},
          "df_after": {},
          "expected_metrics": {
            "warnings": ["clipped col a"],
            "bounds": {"a": [0.0, 10.0]}
          }
        },
        "zscore_stats": {
          "transformer_type": "ZScore",
          "fitted_params": {"stats": {"a": {"mean": 0.0, "std": 1.0}}},
          "df_before": {},
          "df_after": {},
          "expected_metrics": {"stats": {"a": {"mean": 0.0, "std": 1.0}}}
        },
        "elliptic_contamination": {
          "transformer_type": "EllipticEnvelope",
          "fitted_params": {"contamination": 0.1},
          "df_before": {},
          "df_after": {},
          "expected_metrics": {"contamination": 0.1}
        },
        "bucketing_keys": {
          "transformer_type": "KBinsDiscretizer",
          "fitted_params": {"bin_edges": {"a": [0.0, 1.0, 2.0]}, "n_bins": 3},
          "df_before": {},
          "df_after": {},
          "expected_metrics": {"bin_edges": {"a": [0.0, 1.0, 2.0]}, "n_bins": 3}
        },
        "feature_generation": {
          "transformer_type": "FeatureMath",
          "fitted_params": {"operations": [{"op": "add", "columns": ["a", "b"]}]},
          "df_before": {"a": [1.0], "b": [2.0]},
          "df_after": {"a": [1.0], "b": [2.0], "a_plus_b": [3.0]},
          "expected_metrics": {
            "operations_count": 1,
            "operations": [{"op": "add", "columns": ["a", "b"]}],
            "generated_features": ["a_plus_b"]
          }
        }
      }
    },
    "metrics_shape_change": {
      "params": "transformer_type, df_before, df_after, params, rows_before, cols_before, rows_after, cols_after, expected_metrics",
      "test_cases": {
        "row_drop_type": {
          "transformer_type": "Deduplicate",
          "df_before": {"a": [1, 2, 3]},
          "df_after": {"a": [1, 2]},
          "params": {},
          "rows_before": 3,
          "cols_before": ["a"],
          "rows_after": 2,
          "cols_after": ["a"],
          "expected_metrics": {
            "Deduplicate_rows_removed": 1,
            "Deduplicate_rows_remaining": 2,
            "Deduplicate_rows_total": 3,
            "rows_removed": 1,
            "rows_total": 3
          }
        },
        "winsorize_also_computes_clipped": {
          "transformer_type": "Winsorize",
          "df_before": {"a": [1.0, 2.0, 3.0]},
          "df_after": {"a": [1.0, 2.0]},
          "params": {},
          "rows_before": 3,
          "cols_before": ["a"],
          "rows_after": 2,
          "cols_after": ["a"],
          "expected_metrics": {"values_clipped": 0}
        },
        "missing_indicator": {
          "transformer_type": "MissingIndicator",
          "df_before": {"a": [1]},
          "df_after": {"a": [1], "a_missing": [0]},
          "params": {},
          "rows_before": 1,
          "cols_before": ["a"],
          "rows_after": 1,
          "cols_after": ["a", "a_missing"],
          "expected_metrics": {
            "missing_indicators_created": 1,
            "missing_indicators_columns": ["a_missing"]
          }
        },
        "drop_missing_columns": {
          "transformer_type": "DropMissingColumns",
          "df_before": {"a": [1], "b": [null]},
          "df_after": {"a": [1]},
          "params": {},
          "rows_before": 1,
          "cols_before": ["a", "b"],
          "rows_after": 1,
          "cols_after": ["a"],
          "expected_metrics": {"dropped_columns": ["b"], "dropped_columns_count": 1}
        },
        "encoder_with_categories_and_classes_count": {
          "transformer_type": "OneHotEncoder",
          "df_before": {"grade": ["A"]},
          "df_after": {"grade_A": [1], "grade_B": [0]},
          "params": {"columns": ["grade"], "categories_count": 2, "classes_count": 3},
          "rows_before": 1,
          "cols_before": ["grade"],
          "rows_after": 1,
          "cols_after": ["grade_A", "grade_B"],
          "expected_metrics": {
            "new_features_count": 2,
            "encoded_columns_count": 1,
            "categories_count": 2,
            "classes_count": 3
          }
        }
      }
    }
  }
}
