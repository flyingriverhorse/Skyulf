{
  "params": "config, existing_cols, expected_drop",
  "test_cases": {
    "drops_candidates_minus_selected": {
      "config": {"selected_columns": ["a"], "candidate_columns": ["a", "b", "c"]},
      "existing_cols": ["a", "b", "c"],
      "expected_drop": ["b", "c"]
    },
    "no_selected_returns_empty": {
      "config": {"candidate_columns": ["a", "b"]},
      "existing_cols": ["a", "b"],
      "expected_drop": []
    },
    "column_not_in_existing_excluded": {
      "config": {"selected_columns": [], "candidate_columns": ["a", "b"]},
      "existing_cols": ["a"],
      "expected_drop": ["a"]
    },
    "empty_candidates_empty_drop": {
      "config": {"selected_columns": [], "candidate_columns": []},
      "existing_cols": ["a", "b"],
      "expected_drop": []
    }
  }
}
