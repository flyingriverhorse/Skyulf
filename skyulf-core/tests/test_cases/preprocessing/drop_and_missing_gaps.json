{
  "groups": {
    "threshold_ignored": {
      "params": "missing_threshold",
      "test_cases": {
        "non_numeric": {"missing_threshold": "not-a-number"},
        "zero": {"missing_threshold": 0},
        "negative": {"missing_threshold": -5}
      }
    },
    "normalize_subset": {
      "params": "subset, existing_cols, expected",
      "test_cases": {
        "none_returns_none": {"subset": null, "existing_cols": ["a", "b"], "expected": null},
        "empty_returns_none": {"subset": [], "existing_cols": ["a", "b"], "expected": null},
        "filters_to_existing": {
          "subset": ["a", "nonexistent"],
          "existing_cols": ["a", "b"],
          "expected": ["a"]
        },
        "all_missing_returns_none": {"subset": ["nonexistent"], "existing_cols": ["a", "b"], "expected": null}
      }
    }
  }
}
