{
  "groups": {
    "trim_pandas": {
      "params": "values, mode, expected",
      "test_cases": {
        "both_strips_leading_and_trailing": {
          "values": ["  hello  ", " world"],
          "mode": "both",
          "expected": ["hello", "world"]
        },
        "leading_only": {
          "values": ["  hi  "],
          "mode": "leading",
          "expected": ["hi  "]
        },
        "trailing_only": {
          "values": ["  hi  "],
          "mode": "trailing",
          "expected": ["  hi"]
        },
        "unknown_mode_falls_through_to_strip": {
          "values": ["  x  "],
          "mode": "unknown_mode",
          "expected": ["x"]
        }
      }
    },
    "case_pandas": {
      "params": "values, mode, expected",
      "test_cases": {
        "upper": {
          "values": ["hello", "World"],
          "mode": "upper",
          "expected": ["HELLO", "WORLD"]
        },
        "title": {
          "values": ["hello world"],
          "mode": "title",
          "expected": ["Hello World"]
        },
        "sentence_capitalises_first_letter": {
          "values": ["hELLO WORLD"],
          "mode": "sentence",
          "expected": ["Hello world"]
        },
        "lower": {
          "values": ["HELLO", "WoRLd"],
          "mode": "lower",
          "expected": ["hello", "world"]
        },
        "unknown_mode_falls_through_to_lower": {
          "values": ["ABC"],
          "mode": "banana",
          "expected": ["abc"]
        }
      }
    },
    "remove_special_pandas": {
      "params": "values, mode, replacement, expected",
      "test_cases": {
        "keep_alphanumeric_removes_symbols": {
          "values": ["hello, world!", "abc123$%^"],
          "mode": "keep_alphanumeric",
          "replacement": "",
          "expected": ["helloworld", "abc123"]
        },
        "keep_alphanumeric_space_preserves_spaces": {
          "values": ["hello, world!"],
          "mode": "keep_alphanumeric_space",
          "replacement": "",
          "expected": ["hello world"]
        },
        "letters_only": {
          "values": ["abc123!"],
          "mode": "letters_only",
          "replacement": "",
          "expected": ["abc"]
        },
        "digits_only": {
          "values": ["abc123!"],
          "mode": "digits_only",
          "replacement": "",
          "expected": ["123"]
        },
        "unknown_mode_is_noop": {
          "values": ["hello!"],
          "mode": "does_not_exist",
          "replacement": "",
          "expected": ["hello!"]
        },
        "with_replacement_char": {
          "values": ["a$b"],
          "mode": "keep_alphanumeric",
          "replacement": "-",
          "expected": ["a-b"]
        }
      }
    },
    "regex_pandas": {
      "params": "values, mode, pattern, repl, expected",
      "test_cases": {
        "collapse_whitespace": {
          "values": ["hello   world", "  extra  spaces  "],
          "mode": "collapse_whitespace",
          "pattern": null,
          "repl": "",
          "expected": ["hello world", "extra spaces"]
        },
        "extract_digits": {
          "values": ["abc123xyz", "no digits", "42"],
          "mode": "extract_digits",
          "pattern": null,
          "repl": "",
          "expected": ["123", null, "42"]
        },
        "normalize_slash_dates_mm_dd_yyyy": {
          "values": ["12/01/2024", "1/5/2023", "no date here", "5/9/2024 report"],
          "mode": "normalize_slash_dates",
          "pattern": null,
          "repl": "",
          "expected": ["2024-12-01", "2023-01-05", "no date here", "2024-05-09 report"]
        },
        "custom_with_pattern": {
          "values": ["foo123bar", "baz456qux"],
          "mode": "custom",
          "pattern": "\\d+",
          "repl": "NUM",
          "expected": ["fooNUMbar", "bazNUMqux"]
        },
        "custom_without_pattern_is_noop": {
          "values": ["hello"],
          "mode": "custom",
          "pattern": null,
          "repl": "",
          "expected": ["hello"]
        },
        "unknown_mode_is_noop": {
          "values": ["test"],
          "mode": "unknown_mode",
          "pattern": null,
          "repl": "",
          "expected": ["test"]
        }
      }
    },
    "polars_single_op": {
      "params": "texts, operation, expected",
      "test_cases": {
        "trim_leading_strips_left_only": {
          "texts": ["  Hello  ", "WORLD", " foo bar "],
          "operation": {"op": "trim", "mode": "leading"},
          "expected": ["Hello  ", "WORLD", "foo bar "]
        },
        "trim_trailing_strips_right_only": {
          "texts": ["  Hello  ", "WORLD", " foo bar "],
          "operation": {"op": "trim", "mode": "trailing"},
          "expected": ["  Hello", "WORLD", " foo bar"]
        },
        "case_upper": {
          "texts": ["  Hello  ", "WORLD", " foo bar "],
          "operation": {"op": "case", "mode": "upper"},
          "expected": ["  HELLO  ", "WORLD", " FOO BAR "]
        },
        "case_title": {
          "texts": ["hello world", "foo bar"],
          "operation": {"op": "case", "mode": "title"},
          "expected": ["Hello World", "Foo Bar"]
        },
        "case_sentence_capitalises_first_letter": {
          "texts": ["hELLO WORLD"],
          "operation": {"op": "case", "mode": "sentence"},
          "expected": ["Hello world"]
        },
        "remove_special_keep_alphanumeric": {
          "texts": ["hello, world!", "abc123$%"],
          "operation": {"op": "remove_special", "mode": "keep_alphanumeric", "replacement": ""},
          "expected": ["helloworld", "abc123"]
        },
        "regex_collapse_whitespace": {
          "texts": ["hello   world"],
          "operation": {"op": "regex", "mode": "collapse_whitespace"},
          "expected": ["hello world"]
        },
        "regex_extract_digits": {
          "texts": ["abc123xyz"],
          "operation": {"op": "regex", "mode": "extract_digits"},
          "expected": ["123"]
        },
        "regex_custom_pattern": {
          "texts": ["foo123bar"],
          "operation": {"op": "regex", "mode": "custom", "pattern": "\\d+", "repl": "NUM"},
          "expected": ["fooNUMbar"]
        },
        "regex_normalize_slash_dates_mm_dd_yyyy": {
          "texts": ["12/01/2024", "1/5/2023"],
          "operation": {"op": "regex", "mode": "normalize_slash_dates"},
          "expected": ["2024-12-01", "2023-01-05"]
        },
        "regex_custom_without_pattern_is_noop": {
          "texts": ["hello"],
          "operation": {"op": "regex", "mode": "custom"},
          "expected": ["hello"]
        }
      }
    }
  }
}
