{
  "params": "values, rule, replacement, min_value, max_value, expected",
  "test_cases": {
    "negative_replaces_negatives": {
      "values": [-2.0, 0.0, 3.0],
      "rule": "negative",
      "replacement": 0.0,
      "min_value": null,
      "max_value": null,
      "expected": [0.0, 0.0, 3.0]
    },
    "zero_replaces_zeros": {
      "values": [0.0, 1.0, -1.0],
      "rule": "zero",
      "replacement": -99.0,
      "min_value": null,
      "max_value": null,
      "expected": [-99.0, 1.0, -1.0]
    },
    "custom_range_both_bounds": {
      "values": [-1.0, 5.0, 11.0],
      "rule": "custom_range",
      "replacement": 0.0,
      "min_value": 0.0,
      "max_value": 10.0,
      "expected": [0.0, 5.0, 0.0]
    },
    "custom_range_min_only_replaces_below_min": {
      "values": [1.0, 5.0, -3.0],
      "rule": "custom_range",
      "replacement": 0.0,
      "min_value": 2.0,
      "max_value": null,
      "expected": [0.0, 5.0, 0.0]
    },
    "custom_range_max_only_replaces_above_max": {
      "values": [1.0, 5.0, 11.0],
      "rule": "custom_range",
      "replacement": 0.0,
      "min_value": null,
      "max_value": 8.0,
      "expected": [1.0, 5.0, 0.0]
    },
    "custom_range_no_bounds_is_noop": {
      "values": [1.0, 2.0],
      "rule": "custom_range",
      "replacement": 0.0,
      "min_value": null,
      "max_value": null,
      "expected": [1.0, 2.0]
    },
    "unknown_rule_is_noop": {
      "values": [1.0, 2.0],
      "rule": "unknown_rule",
      "replacement": 0.0,
      "min_value": null,
      "max_value": null,
      "expected": [1.0, 2.0]
    }
  }
}
