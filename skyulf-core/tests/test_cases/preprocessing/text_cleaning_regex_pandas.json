{
  "params": "values, mode, pattern, repl, expected",
  "test_cases": {
    "collapse_whitespace": {
      "values": ["hello   world", "  extra  spaces  "],
      "mode": "collapse_whitespace",
      "pattern": null,
      "repl": "",
      "expected": ["hello world", "extra spaces"]
    },
    "extract_digits": {
      "values": ["abc123xyz", "no digits", "42"],
      "mode": "extract_digits",
      "pattern": null,
      "repl": "",
      "expected": ["123", null, "42"]
    },
    "normalize_slash_dates_is_noop_placeholder": {
      "values": ["12/01/2024"],
      "mode": "normalize_slash_dates",
      "pattern": null,
      "repl": "",
      "expected": ["12/01/2024"]
    },
    "custom_with_pattern": {
      "values": ["foo123bar", "baz456qux"],
      "mode": "custom",
      "pattern": "\\d+",
      "repl": "NUM",
      "expected": ["fooNUMbar", "bazNUMqux"]
    },
    "custom_without_pattern_is_noop": {
      "values": ["hello"],
      "mode": "custom",
      "pattern": null,
      "repl": "",
      "expected": ["hello"]
    },
    "unknown_mode_is_noop": {
      "values": ["test"],
      "mode": "unknown_mode",
      "pattern": null,
      "repl": "",
      "expected": ["test"]
    }
  }
}
