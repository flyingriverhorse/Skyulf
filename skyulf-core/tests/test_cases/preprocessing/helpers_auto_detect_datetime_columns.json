{
  "params": "frame_type, datetime_columns, other_columns, expected",
  "test_cases": {
    "pandas_datetime64": {
      "frame_type": "pandas",
      "datetime_columns": {"when": ["2020-01-01", "2020-01-02"]},
      "other_columns": {"num": [1, 2]},
      "expected": ["when"]
    },
    "pandas_none_present": {
      "frame_type": "pandas",
      "datetime_columns": {},
      "other_columns": {"num": [1, 2]},
      "expected": []
    },
    "polars_date_and_datetime": {
      "frame_type": "polars",
      "datetime_columns": {
        "d": ["2020-01-01", "2020-01-02"],
        "dt": ["2020-01-01T01:00:00", "2020-01-02T02:00:00"]
      },
      "other_columns": {"num": [1, 2]},
      "expected": ["d", "dt"]
    }
  }
}
