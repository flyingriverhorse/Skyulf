{
  "params": "transformer_type, df_before, df_after, params, rows_before, cols_before, rows_after, cols_after, expected_metrics",
  "test_cases": {
    "row_drop_type": {
      "transformer_type": "Deduplicate",
      "df_before": {"a": [1, 2, 3]},
      "df_after": {"a": [1, 2]},
      "params": {},
      "rows_before": 3,
      "cols_before": ["a"],
      "rows_after": 2,
      "cols_after": ["a"],
      "expected_metrics": {
        "Deduplicate_rows_removed": 1,
        "Deduplicate_rows_remaining": 2,
        "Deduplicate_rows_total": 3,
        "rows_removed": 1,
        "rows_total": 3
      }
    },
    "winsorize_also_computes_clipped": {
      "transformer_type": "Winsorize",
      "df_before": {"a": [1.0, 2.0, 3.0]},
      "df_after": {"a": [1.0, 2.0]},
      "params": {},
      "rows_before": 3,
      "cols_before": ["a"],
      "rows_after": 2,
      "cols_after": ["a"],
      "expected_metrics": {"values_clipped": 0}
    },
    "missing_indicator": {
      "transformer_type": "MissingIndicator",
      "df_before": {"a": [1]},
      "df_after": {"a": [1], "a_missing": [0]},
      "params": {},
      "rows_before": 1,
      "cols_before": ["a"],
      "rows_after": 1,
      "cols_after": ["a", "a_missing"],
      "expected_metrics": {
        "missing_indicators_created": 1,
        "missing_indicators_columns": ["a_missing"]
      }
    },
    "drop_missing_columns": {
      "transformer_type": "DropMissingColumns",
      "df_before": {"a": [1], "b": [null]},
      "df_after": {"a": [1]},
      "params": {},
      "rows_before": 1,
      "cols_before": ["a", "b"],
      "rows_after": 1,
      "cols_after": ["a"],
      "expected_metrics": {"dropped_columns": ["b"], "dropped_columns_count": 1}
    },
    "encoder_with_categories_and_classes_count": {
      "transformer_type": "OneHotEncoder",
      "df_before": {"grade": ["A"]},
      "df_after": {"grade_A": [1], "grade_B": [0]},
      "params": {"columns": ["grade"], "categories_count": 2, "classes_count": 3},
      "rows_before": 1,
      "cols_before": ["grade"],
      "rows_after": 1,
      "cols_after": ["grade_A", "grade_B"],
      "expected_metrics": {
        "new_features_count": 2,
        "encoded_columns_count": 1,
        "categories_count": 2,
        "classes_count": 3
      }
    }
  }
}
