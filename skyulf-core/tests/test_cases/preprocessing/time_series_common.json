{
  "groups": {
    "resolve_columns": {
      "params": "columns, available, expected",
      "test_cases": {
        "filters_to_available_preserves_order": {
          "columns": ["a", "z", "b"],
          "available": ["a", "b", "c"],
          "expected": ["a", "b"]
        },
        "none_returns_empty": {
          "columns": null,
          "available": ["a", "b"],
          "expected": []
        },
        "empty_list_returns_empty": {
          "columns": [],
          "available": ["a", "b"],
          "expected": []
        }
      }
    },
    "coerce_lags": {
      "params": "lags_input, expected",
      "test_cases": {
        "single_int_wrapped": {
          "lags_input": 3,
          "expected": [3]
        },
        "dedups_and_sorts": {
          "lags_input": [3, 1, 3, 2],
          "expected": [1, 2, 3]
        },
        "drops_non_positive_values": {
          "lags_input": [0, -1, 2],
          "expected": [2]
        },
        "none_returns_empty": {
          "lags_input": null,
          "expected": []
        },
        "empty_list_returns_empty": {
          "lags_input": [],
          "expected": []
        }
      }
    },
    "coerce_aggregations": {
      "params": "aggregations_input, expected",
      "test_cases": {
        "single_string_wrapped": {
          "aggregations_input": "mean",
          "expected": ["mean"]
        },
        "filters_unknown_names": {
          "aggregations_input": ["mean", "bogus", "sum"],
          "expected": ["mean", "sum"]
        },
        "none_returns_empty": {
          "aggregations_input": null,
          "expected": []
        },
        "empty_list_returns_empty": {
          "aggregations_input": [],
          "expected": []
        }
      }
    },
    "sort_pandas": {
      "params": "df_data, sort_by, expected_cols",
      "test_cases": {
        "sorts_by_given_column": {
          "df_data": {"t": [3, 1, 2], "v": ["c", "a", "b"]},
          "sort_by": "t",
          "expected_cols": {"t": [1, 2, 3], "v": ["a", "b", "c"]}
        },
        "passthrough_when_column_missing": {
          "df_data": {"t": [3, 1, 2]},
          "sort_by": "nonexistent",
          "expected_cols": {"t": [3, 1, 2]}
        },
        "passthrough_when_sort_by_none": {
          "df_data": {"t": [3, 1, 2]},
          "sort_by": null,
          "expected_cols": {"t": [3, 1, 2]}
        }
      }
    }
  }
}
