{
  "params": "texts, operation, expected",
  "test_cases": {
    "trim_leading_strips_left_only": {
      "texts": ["  Hello  ", "WORLD", " foo bar "],
      "operation": {"op": "trim", "mode": "leading"},
      "expected": ["Hello  ", "WORLD", "foo bar "]
    },
    "trim_trailing_strips_right_only": {
      "texts": ["  Hello  ", "WORLD", " foo bar "],
      "operation": {"op": "trim", "mode": "trailing"},
      "expected": ["  Hello", "WORLD", " foo bar"]
    },
    "case_upper": {
      "texts": ["  Hello  ", "WORLD", " foo bar "],
      "operation": {"op": "case", "mode": "upper"},
      "expected": ["  HELLO  ", "WORLD", " FOO BAR "]
    },
    "case_title": {
      "texts": ["hello world", "foo bar"],
      "operation": {"op": "case", "mode": "title"},
      "expected": ["Hello World", "Foo Bar"]
    },
    "case_sentence_capitalises_first_letter": {
      "texts": ["hELLO WORLD"],
      "operation": {"op": "case", "mode": "sentence"},
      "expected": ["Hello world"]
    },
    "remove_special_keep_alphanumeric": {
      "texts": ["hello, world!", "abc123$%"],
      "operation": {"op": "remove_special", "mode": "keep_alphanumeric", "replacement": ""},
      "expected": ["helloworld", "abc123"]
    },
    "regex_collapse_whitespace": {
      "texts": ["hello   world"],
      "operation": {"op": "regex", "mode": "collapse_whitespace"},
      "expected": ["hello world"]
    },
    "regex_extract_digits": {
      "texts": ["abc123xyz"],
      "operation": {"op": "regex", "mode": "extract_digits"},
      "expected": ["123"]
    },
    "regex_custom_pattern": {
      "texts": ["foo123bar"],
      "operation": {"op": "regex", "mode": "custom", "pattern": "\\d+", "repl": "NUM"},
      "expected": ["fooNUMbar"]
    },
    "regex_normalize_slash_dates_is_noop_placeholder": {
      "texts": ["12/01/2024"],
      "operation": {"op": "regex", "mode": "normalize_slash_dates"},
      "expected": ["12/01/2024"]
    },
    "regex_custom_without_pattern_is_noop": {
      "texts": ["hello"],
      "operation": {"op": "regex", "mode": "custom"},
      "expected": ["hello"]
    }
  }
}
