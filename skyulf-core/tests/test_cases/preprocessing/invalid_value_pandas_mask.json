{
  "params": "values, rule, min_value, max_value, expected",
  "test_cases": {
    "negative_marks_negatives": {
      "values": [-1.0, 0.0, 1.0],
      "rule": "negative",
      "min_value": null,
      "max_value": null,
      "expected": [true, false, false]
    },
    "negative_to_nan_alias": {
      "values": [-2.0, 3.0],
      "rule": "negative_to_nan",
      "min_value": null,
      "max_value": null,
      "expected": [true, false]
    },
    "zero_marks_zeros": {
      "values": [0.0, 1.0, -1.0, 0.0],
      "rule": "zero",
      "min_value": null,
      "max_value": null,
      "expected": [true, false, false, true]
    },
    "custom_range_both_bounds": {
      "values": [0.0, 5.0, 11.0, -1.0],
      "rule": "custom_range",
      "min_value": 0.0,
      "max_value": 10.0,
      "expected": [false, false, true, true]
    },
    "custom_range_min_only": {
      "values": [1.0, 5.0, -3.0],
      "rule": "custom_range",
      "min_value": 2.0,
      "max_value": null,
      "expected": [true, false, true]
    },
    "custom_range_max_only": {
      "values": [1.0, 5.0, 11.0],
      "rule": "custom_range",
      "min_value": null,
      "max_value": 8.0,
      "expected": [false, false, true]
    },
    "custom_range_no_bounds_returns_none": {
      "values": [1.0, 2.0],
      "rule": "custom_range",
      "min_value": null,
      "max_value": null,
      "expected": null
    },
    "unknown_rule_returns_none": {
      "values": [1.0, 2.0],
      "rule": "does_not_exist",
      "min_value": null,
      "max_value": null,
      "expected": null
    }
  }
}
