{
  "params": "before, after, expected",
  "test_cases": {
    "identical_frames": {
      "before": {"x": [1.0, 2.0, 3.0]},
      "after": {"x": [1.0, 2.0, 3.0]},
      "expected": 0
    },
    "shape_mismatch": {
      "before": {"x": [1.0, 2.0]},
      "after": {"x": [1.0, 2.0, 3.0]},
      "expected": 0
    },
    "modified_cell": {
      "before": {"x": [1.0, 2.0, 3.0]},
      "after": {"x": [99.0, 2.0, 3.0]},
      "expected": 1
    },
    "non_tuple_non_dataframe": {
      "before": "not_a_frame",
      "after": 123,
      "expected": 0
    }
  }
}
