{
  "params": "values, params, expected",
  "test_cases": {
    "negative_rule_replaces_with_nan": {
      "values": [-3.0, -1.0, 0.0, 1.0, 5.0],
      "params": {
        "columns": ["v"],
        "rule": "negative",
        "replacement": null,
        "replace_inf": false,
        "replace_neg_inf": false
      },
      "expected": [null, null, 0.0, 1.0, 5.0]
    },
    "zero_rule_replaces_zeros": {
      "values": [0.0, 1.0, 0.0, 5.0],
      "params": {
        "columns": ["v"],
        "rule": "zero",
        "replacement": null,
        "replace_inf": false,
        "replace_neg_inf": false
      },
      "expected": [null, 1.0, null, 5.0]
    },
    "custom_range_replaces_out_of_range": {
      "values": [-5.0, 5.0, 15.0],
      "params": {
        "columns": ["v"],
        "rule": "custom_range",
        "min_value": 1.0,
        "max_value": 9.0,
        "replacement": -1.0,
        "replace_inf": false,
        "replace_neg_inf": false
      },
      "expected": [-1.0, 5.0, -1.0]
    },
    "replace_inf_only": {
      "values": [Infinity, -Infinity, 1.0],
      "params": {
        "columns": ["v"],
        "replace_inf": true,
        "replace_neg_inf": false,
        "replacement": 0.0
      },
      "expected": [0.0, -Infinity, 1.0]
    },
    "replace_neg_inf_only": {
      "values": [Infinity, -Infinity, 2.0],
      "params": {
        "columns": ["v"],
        "replace_inf": false,
        "replace_neg_inf": true,
        "replacement": 0.0
      },
      "expected": [Infinity, 0.0, 2.0]
    },
    "custom_value_sentinel_overrides_replacement": {
      "values": [-1.0, 2.0, -3.0],
      "params": {
        "columns": ["v"],
        "rule": "negative",
        "replacement": null,
        "value": -999.0,
        "replace_inf": false,
        "replace_neg_inf": false
      },
      "expected": [-999.0, 2.0, -999.0]
    }
  }
}
