{
  "params": "params, expect_unchanged",
  "test_cases": {
    "empty_output_columns_returns_unchanged": {
      "params": {
        "columns": ["text"],
        "output_columns": [],
        "model_name": "any",
        "normalize": true,
        "drop_original": false
      },
      "expect_unchanged": true
    },
    "missing_column_in_params_returns_unchanged": {
      "params": {
        "columns": ["nonexistent"],
        "output_columns": ["nonexistent__emb__0"],
        "model_name": "any",
        "normalize": true,
        "drop_original": false
      },
      "expect_unchanged": true
    }
  }
}
