{
  "params": "columns, available, expected",
  "test_cases": {
    "filters_to_available_preserves_order": {
      "columns": ["a", "missing", "b"],
      "available": ["a", "b"],
      "expected": ["a", "b"]
    },
    "none_returns_empty": {
      "columns": null,
      "available": ["a"],
      "expected": []
    },
    "empty_list_returns_empty": {
      "columns": [],
      "available": ["a"],
      "expected": []
    }
  }
}
