{
  "params": "frame_type, frame_columns, requested, expected",
  "test_cases": {
    "filters_missing": {
      "frame_type": "pandas",
      "frame_columns": {"a": [1], "b": [2]},
      "requested": ["a", "c", "b"],
      "expected": ["a", "b"]
    },
    "preserves_requested_order": {
      "frame_type": "pandas",
      "frame_columns": {"a": [1], "b": [2], "c": [3]},
      "requested": ["c", "a"],
      "expected": ["c", "a"]
    },
    "empty_requested_returns_empty": {
      "frame_type": "pandas",
      "frame_columns": {"a": [1]},
      "requested": [],
      "expected": []
    },
    "none_present_returns_empty": {
      "frame_type": "pandas",
      "frame_columns": {"a": [1]},
      "requested": ["x", "y"],
      "expected": []
    },
    "works_with_polars_frame": {
      "frame_type": "polars",
      "frame_columns": {"a": [1], "b": [2]},
      "requested": ["b", "z"],
      "expected": ["b"]
    }
  }
}
