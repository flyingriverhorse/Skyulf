{
  "params": "df_data, sort_by, expected_v",
  "test_cases": {
    "noop_without_sort_by": {
      "df_data": {"v": [3, 1, 2]},
      "sort_by": null,
      "expected_v": [3, 1, 2]
    },
    "sorts_stable": {
      "df_data": {"t": [3, 1, 2], "v": ["c", "a", "b"]},
      "sort_by": "t",
      "expected_v": ["a", "b", "c"]
    }
  }
}
