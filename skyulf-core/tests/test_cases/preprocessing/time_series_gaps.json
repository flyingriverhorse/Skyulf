{
  "groups": {
    "resolve_columns": {
      "params": "columns, available, expected",
      "test_cases": {
        "filters_to_available_preserves_order": {
          "columns": ["a", "missing", "b"],
          "available": ["a", "b"],
          "expected": ["a", "b"]
        },
        "none_returns_empty": {
          "columns": null,
          "available": ["a"],
          "expected": []
        },
        "empty_list_returns_empty": {
          "columns": [],
          "available": ["a"],
          "expected": []
        }
      }
    },
    "coerce_lags": {
      "params": "lags_input, expected",
      "test_cases": {
        "single_int_wrapped": {
          "lags_input": 5,
          "expected": [5]
        },
        "drops_non_positive_and_dedupes": {
          "lags_input": [2, 2, 0, -1, 1],
          "expected": [1, 2]
        }
      }
    },
    "coerce_aggregations": {
      "params": "aggregations_input, expected",
      "test_cases": {
        "single_string_wrapped": {
          "aggregations_input": "mean",
          "expected": ["mean"]
        },
        "filters_unknown_names": {
          "aggregations_input": ["mean", "bogus", "sum"],
          "expected": ["mean", "sum"]
        }
      }
    },
    "sort_pandas": {
      "params": "df_data, sort_by, expected_v",
      "test_cases": {
        "noop_without_sort_by": {
          "df_data": {"v": [3, 1, 2]},
          "sort_by": null,
          "expected_v": [3, 1, 2]
        },
        "sorts_stable": {
          "df_data": {"t": [3, 1, 2], "v": ["c", "a", "b"]},
          "sort_by": "t",
          "expected_v": ["a", "b", "c"]
        }
      }
    },
    "apply_noop_without_config": {
      "params": "node, config, expected_columns, engine",
      "test_cases": {
        "lag_pandas_noop": {
          "node": "lag",
          "config": {"columns": [], "lags": [1]},
          "expected_columns": ["v"],
          "engine": "pandas"
        },
        "lag_polars_noop": {
          "node": "lag",
          "config": {"columns": [], "lags": [1]},
          "expected_columns": ["v"],
          "engine": "polars"
        },
        "rolling_pandas_noop": {
          "node": "rolling",
          "config": {"columns": [], "aggregations": ["mean"]},
          "expected_columns": ["v"],
          "engine": "pandas"
        },
        "rolling_polars_noop": {
          "node": "rolling",
          "config": {"columns": [], "aggregations": ["mean"]},
          "expected_columns": ["v"],
          "engine": "polars"
        },
        "date_features_pandas_noop": {
          "node": "date_features",
          "config": {"columns": [], "features": ["year"]},
          "expected_columns": ["d"],
          "engine": "pandas"
        },
        "date_features_polars_noop": {
          "node": "date_features",
          "config": {"columns": [], "features": ["year"]},
          "expected_columns": ["d"],
          "engine": "polars"
        }
      }
    }
  }
}
