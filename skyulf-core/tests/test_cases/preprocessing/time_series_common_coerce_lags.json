{
  "params": "lags_input, expected",
  "test_cases": {
    "single_int_wrapped": {
      "lags_input": 3,
      "expected": [3]
    },
    "dedups_and_sorts": {
      "lags_input": [3, 1, 3, 2],
      "expected": [1, 2, 3]
    },
    "drops_non_positive_values": {
      "lags_input": [0, -1, 2],
      "expected": [2]
    },
    "none_returns_empty": {
      "lags_input": null,
      "expected": []
    },
    "empty_list_returns_empty": {
      "lags_input": [],
      "expected": []
    }
  }
}
