{
  "params": "columns, target_column, y_name, encoder_name, expected, expect_warning",
  "test_cases": {
    "removes_and_warns": {
      "columns": ["city", "target"],
      "target_column": "target",
      "y_name": null,
      "encoder_name": "OneHotEncoder",
      "expected": ["city"],
      "expect_warning": true
    },
    "uses_y_name_when_config_missing": {
      "columns": ["city", "target"],
      "target_column": null,
      "y_name": "target",
      "encoder_name": "DummyEncoder",
      "expected": ["city"],
      "expect_warning": false
    },
    "noop_for_safe_encoders": {
      "columns": ["city", "target"],
      "target_column": "target",
      "y_name": null,
      "encoder_name": "LabelEncoder",
      "expected": ["city", "target"],
      "expect_warning": false
    },
    "noop_when_target_not_in_columns": {
      "columns": ["city"],
      "target_column": "target",
      "y_name": null,
      "encoder_name": "OneHotEncoder",
      "expected": ["city"],
      "expect_warning": false
    }
  }
}
